@startuml 05_statemachine
skinparam backgroundColor #FAFBFF
skinparam state {
  BackgroundColor #EEF3FF
  BorderColor #3A5CC5
  ArrowColor #2255AA
  FontColor #111111
}
skinparam note {
  BackgroundColor #FFF9E6
  BorderColor #C8A800
}

title <b>Projectile – State Machine</b>

[*] --> IDLE

IDLE --> AIMING : startAiming(isPlayer1Turn)

AIMING --> AIMING : update()\n[angle oscillates MIN↔MAX\nunless angleLocked]

AIMING --> FLYING : fire()\n[compute vx, vy from angle]

FLYING --> FLYING : update()\n[x+=vx, y+=vy, vy+=GRAVITY\nappend trail point]

FLYING --> IDLE : isHit() == true\n[hit box detected]

FLYING --> IDLE : x<0 OR x>800\nOR y > GROUND_Y+90\n[miss / out of bounds]

IDLE --> [*]

note right of AIMING
  if angleLocked (Cat ability):
  angle stays fixed,
  no oscillation
end note

note right of FLYING
  Trail buffer: last 10 positions
  Used for aiming arc preview
  when state == AIMING
end note

@enduml
